# All of these are OPTIONAL. trader-stack runs with zero keys set —
# Gemma 4 is local via Ollama, and OHLCV comes from yfinance (free).
#
# Set these only if you want to upgrade specific data sources:

# News search used by TradingAgents' News Analyst. If empty, the analyst
# falls back to yfinance news.
TAVILY_API_KEY=

# Alpha Vantage for richer fundamentals data inside TradingAgents.
ALPHA_VANTAGE_API_KEY=

# FinnHub for richer fundamentals/news. Free tier exists.
FINNHUB_API_KEY=

# Force-call the quantitative forecast tool even if the Technical Analyst
# doesn't pick it up on its own. Useful if Gemma's function-calling
# reliability disappoints you on a given run.
FORCE_FORECAST=false
